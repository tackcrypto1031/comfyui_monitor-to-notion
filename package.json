{
  "name": "comfyui-monitor",
  "version": "1.0.0",
  "description": "ComfyUI 內網監控工具 - 即時監控多台 ComfyUI 狀態並同步到 Notion",
  "main": "dist/server/server/server.js",
  "scripts": {
    "dev": "npm run build:web && npm run start:web",
    "build": "npm run build:web",
    "build:web": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start:web": "node dist/server/server/server.js",
    "preview": "npm run start:web",
    "package:portable": "npm run build:web && powershell -ExecutionPolicy Bypass -File scripts\\package-portable.ps1",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "comfyui",
    "monitor",
    "websocket",
    "notion"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.1.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@notionhq/client": "^5.13.0",
    "bufferutil": "^4.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.16.0"
  }
}
